/* ===== 基础变量定义 ===== */
:root
  --radius-large: 0.75rem
  --radius-medium: 0.5rem
  --radius-small: 0.25rem
  --space-1: 0.25rem
  --space-2: 0.5rem
  --space-3: 0.75rem
  --space-4: 1rem
  --space-5: 1.25rem
  --space-6: 1.5rem
  --space-8: 2rem
  --control-size: 2.75rem
  --content-delay: 150ms

/* ===== 主题相关变量（极简中性灰阶，模拟 x.ai 视觉语言） =====
   注: 保留 --hue 兼容性，但视觉调色板强制中性化以贯彻"无饱和色块"原则。
   仅 --primary 保留细微 hue，用于 link/focus 等点缀。 */
:root
  --primary: oklch(0.30 0 0)
  --page-bg: oklch(1 0 0)
  --card-bg: transparent
  --card-bg-transparent: transparent

  --btn-content: oklch(0.25 0 0)
  --btn-regular-bg: transparent
  --btn-regular-bg-hover: oklch(0.94 0 0)
  --btn-regular-bg-active: oklch(0.90 0 0)

  --btn-plain-bg-hover: oklch(0.94 0 0)
  --btn-plain-bg-active: oklch(0.90 0 0)

  --btn-card-bg-hover: oklch(0.96 0 0)
  --btn-card-bg-active: oklch(0.92 0 0)

  --enter-btn-bg: transparent
  --enter-btn-bg-hover: oklch(0.94 0 0)
  --enter-btn-bg-active: oklch(0.90 0 0)

  --deep-text: oklch(0.10 0 0)
  --title-active: oklch(0.30 0 0)

  --line-divider: oklch(0.85 0 0)
  --line-color: oklch(0.85 0 0)
  --meta-divider: oklch(0.75 0 0)
  --content-meta: oklch(0.45 0 0)

  --inline-code-bg: oklch(0.95 0 0)
  --inline-code-color: oklch(0.20 0 0)
  --selection-bg: oklch(0.85 0 0)
  --codeblock-bg: oklch(0.97 0 0)
  --codeblock-topbar-bg: oklch(0.93 0 0)
  --codeblock-border: oklch(0.85 0 0)

  --license-block-bg: oklch(0.97 0 0)

  --link-underline: oklch(0.85 0 0)
  --link-hover: oklch(0.50 0 0)
  --link-active: oklch(0.30 0 0)

  --float-panel-bg: oklch(1 0 0)

  --scrollbar-bg-light: rgba(0, 0, 0, 0.4)
  --scrollbar-bg-hover-light: rgba(0, 0, 0, 0.5)
  --scrollbar-bg-active-light: rgba(0, 0, 0, 0.6)

  --scrollbar-bg-dark: rgba(255, 255, 255, 0.4)
  --scrollbar-bg-hover-dark: rgba(255, 255, 255, 0.5)
  --scrollbar-bg-active-dark: rgba(255, 255, 255, 0.6)

  --scrollbar-bg: var(--scrollbar-bg-light)
  --scrollbar-bg-hover: var(--scrollbar-bg-hover-light)
  --scrollbar-bg-active: var(--scrollbar-bg-active-light)

  --display-light-icon: 1
  --display-dark-icon: 0

  --admonitions-color-tip: oklch(0.55 0 0)
  --admonitions-color-note: oklch(0.55 0 0)
  --admonitions-color-important: oklch(0.55 0 0)
  --admonitions-color-warning: oklch(0.55 0 0)
  --admonitions-color-caution: oklch(0.40 0 0)

  --guestbook-panel: transparent
  --guestbook-surface: transparent
  --guestbook-editor-bg: #F7F7F7
  --guestbook-editor-text: #171717
  --guestbook-editor-muted: #666666
  --guestbook-editor-line: #D6D6D6
  --guestbook-editor-hover: #EAEAEA
  --guestbook-focus: #3D3D3D
  --guestbook-send-bg: #171717
  --guestbook-send-text: #FFFFFF
  --guestbook-link: #22C55E
  --guestbook-overlay: rgb(0 0 0 / 0.58)
  --guestbook-bubble: #262626
  --guestbook-bubble-text: #FFFFFF
  --guestbook-admin-bubble: #FFFFFF
  --guestbook-admin-text: #111111
  --guestbook-muted: var(--content-meta)
  --guestbook-line: var(--line-divider)
  --guestbook-danger: var(--admonitions-color-caution)
  --guestbook-success: var(--admonitions-color-tip)
  --guestbook-avatar-size: 2.625rem
  --guestbook-chat-height: min(74vh, 47.5rem)
  --guestbook-chat-min-height: 37.5rem
  --guestbook-chat-max-width: 90rem
  --guestbook-sidebar-width: 18rem
  --guestbook-viewport-offset: 4.75rem
  --guestbook-mobile-dock-clearance: 6.25rem

  /* TOC 极简：去 badge 底色、hover 仅细线反相 */
  --toc-badge-bg: transparent
  --toc-btn-hover: oklch(0.94 0 0)
  --toc-btn-active: oklch(0.90 0 0)
  --toc-width: 18rem
  --toc-item-active: oklch(0.20 0 0)

  --color-selection-bar: linear-gradient(to right, oklch(0.20 0 0), oklch(0.50 0 0), oklch(0.80 0 0))

  /* 7 色彩虹渐变（红橙黄绿青蓝紫），用于幽灵徽章文字 */
  --rainbow-7: linear-gradient(135deg, #FF5252 0%, #FF9800 16%, #FFEB3B 33%, #4CAF50 50%, #00BCD4 66%, #2196F3 83%, #9C27B0 100%)

/* 卡片"跟随主题色相"模式被废弃为 no-op */
:root:not(.dark) body.card-follow-theme-hue
  --card-bg: transparent

/* 暗色主题：纯黑底 + 白前景，所有色块去饱和 */
:root.dark
  --primary: oklch(0.85 0 0)
  --page-bg: oklch(0.08 0 0)
  --card-bg: transparent
  --card-bg-transparent: transparent

  --deep-text: oklch(0.90 0 0)
  --title-active: oklch(0.70 0 0)

  --btn-content: oklch(0.85 0 0)
  --btn-regular-bg: transparent
  --btn-regular-bg-hover: oklch(0.18 0 0)
  --btn-regular-bg-active: oklch(0.22 0 0)

  --btn-plain-bg-hover: oklch(0.18 0 0)
  --btn-plain-bg-active: oklch(0.22 0 0)

  --btn-card-bg-hover: oklch(0.16 0 0)
  --btn-card-bg-active: oklch(0.20 0 0)

  --line-divider: oklch(0.25 0 0)
  --line-color: oklch(0.25 0 0)
  --meta-divider: oklch(0.35 0 0)
  --content-meta: oklch(0.65 0 0)

  --inline-code-bg: oklch(0.18 0 0)
  --inline-code-color: oklch(0.85 0 0)
  --selection-bg: oklch(0.30 0 0)
  --codeblock-bg: #131313
  --codeblock-topbar-bg: oklch(0.18 0 0)
  --codeblock-border: #242424

  --license-block-bg: oklch(0.12 0 0)

  --link-underline: oklch(0.30 0 0)
  --link-hover: oklch(0.65 0 0)
  --link-active: oklch(0.80 0 0)

  --float-panel-bg: oklch(0.10 0 0)

  --scrollbar-bg: var(--scrollbar-bg-dark)
  --scrollbar-bg-hover: var(--scrollbar-bg-hover-dark)
  --scrollbar-bg-active: var(--scrollbar-bg-active-dark)

  --display-light-icon: 0
  --display-dark-icon: 1

  --admonitions-color-tip: oklch(0.75 0 0)
  --admonitions-color-note: oklch(0.75 0 0)
  --admonitions-color-important: oklch(0.75 0 0)
  --admonitions-color-warning: oklch(0.75 0 0)
  --admonitions-color-caution: oklch(0.85 0 0)

  --guestbook-panel: transparent
  --guestbook-surface: transparent
  --guestbook-editor-bg: #2D2D2D
  --guestbook-editor-text: #FFFFFF
  --guestbook-editor-muted: #B8B8B8
  --guestbook-editor-line: #555555
  --guestbook-editor-hover: #262626
  --guestbook-focus: #D6D6D6
  --guestbook-send-bg: #FFFFFF
  --guestbook-send-text: #111111
  --guestbook-link: #22C55E
  --guestbook-overlay: rgb(0 0 0 / 0.72)
  --guestbook-bubble: #262626
  --guestbook-bubble-text: #FFFFFF
  --guestbook-admin-bubble: #FFFFFF
  --guestbook-admin-text: #111111
  --guestbook-muted: var(--content-meta)
  --guestbook-line: var(--line-divider)
  --guestbook-danger: var(--admonitions-color-caution)
  --guestbook-success: var(--admonitions-color-tip)

  --toc-badge-bg: transparent
  --toc-btn-hover: oklch(0.18 0 0)
  --toc-btn-active: oklch(0.22 0 0)
  --toc-item-active: oklch(0.85 0 0)

  --color-selection-bar: linear-gradient(to right, oklch(0.85 0 0), oklch(0.55 0 0), oklch(0.25 0 0))

/* ===== 阴影变量（仅保留实际使用的） ===== */
:root
  --shadow-md: none
  --shadow-navbar: none
  --shadow-navbar-dark: none

/* ===== 边框半径变量 ===== */
:root
  --radius-full: 9999px
