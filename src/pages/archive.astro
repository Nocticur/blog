---
import ArchivePanel from "@components/controls/ArchivePanel.svelte";
import ArchiveStats from "@components/widget/ArchiveStats.svelte";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import PageTitle from "@/components/common/PageTitle.astro";
import { siteConfig } from "@/config";
import { getSortedPostsList } from "@/utils/content-utils";

const sortedPostsList = await getSortedPostsList();
const title = i18n(I18nKey.archive);
const archiveStatsConfig = siteConfig.archiveStats;
const timezone = siteConfig.timezone ?? "UTC";
const currentYear = Number(
	new Intl.DateTimeFormat("en-US", {
		timeZone: timezone,
		year: "numeric",
	}).format(new Date()),
);
const currentYearPosts = sortedPostsList.filter(
	(post) =>
		Number(
			new Intl.DateTimeFormat("en-US", {
				timeZone: timezone,
				year: "numeric",
			}).format(post.data.published),
		) === currentYear,
).length;
const githubConfig = archiveStatsConfig?.github;
---

<MainGridLayout title={title}>
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-4 py-6 md:px-9 relative w-full">
      <div class="mb-6">
        <PageTitle
          title={title}
          variant="stacked"
        />
      </div>
      <ArchiveStats
        totalPosts={sortedPostsList.length}
        currentYearPosts={currentYearPosts}
        annualPostGoal={archiveStatsConfig?.annualPostGoal ?? 0}
        githubEnabled={githubConfig?.enabled ?? false}
        githubUsername={githubConfig?.username ?? ""}
        timezone={timezone}
        totalPostsLabel={i18n(I18nKey.archiveStatsTotalPosts)}
        githubLabel={i18n(I18nKey.archiveStatsGithub)}
        yearPostsLabel={i18n(I18nKey.archiveStatsYearPosts)}
        progressLabel={i18n(I18nKey.archiveStatsProgress)}
        goalLabel={i18n(I18nKey.archiveStatsGoal)}
        loadingLabel={i18n(I18nKey.archiveStatsLoading)}
        unavailableLabel={i18n(I18nKey.archiveStatsUnavailable)}
        client:load
      />
      <ArchivePanel sortedPosts={sortedPostsList} client:load />
    </div>
  </div>
</MainGridLayout>
