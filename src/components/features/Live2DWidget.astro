---
import Icon from "@/components/common/Icon.astro";
import MessageBox from "@/components/common/PioMessageBox.astro";
import type { Live2DModelConfig } from "@/types/config";
import { url } from "@/utils/url-utils";

interface Props {
	config: Live2DModelConfig;
}

const { config } = Astro.props;

const position = config.position || {
	corner: "bottom-right" as const,
	offsetX: 20,
	offsetY: 20,
};
const size = config.size || { width: 280, height: 250 };
---

<div
	id="live2d-widget"
	class="live2d-widget live2d-initial"
	data-position={position.corner}
	style={`
    width: ${size.width}px;
    height: ${size.height}px;
    ${position.corner?.includes("right") ? "right" : "left"}: ${position.offsetX}px;
    ${position.corner?.includes("top") ? "top" : "bottom"}: ${position.offsetY}px;
  `}
>
	<canvas id="live2d-canvas" width={size.width} height={size.height}></canvas>

	<div class="live2d-toolbar">
		<button class="live2d-toolbar-btn" id="toolbar-drag" title="移动">
			<Icon name="material-symbols:drag-indicator" class="text-base" />
		</button>
		<button class="live2d-toolbar-btn" id="toolbar-switch" title="切换动画组">
			<Icon name="material-symbols:swap-horiz" class="text-base" />
		</button>
		<button class="live2d-toolbar-btn active" id="toolbar-info" title="作者信息">
			<Icon name="material-symbols:info" class="text-base" />
		</button>
		<button class="live2d-toolbar-btn" id="toolbar-close" title="关闭">
			<Icon name="material-symbols:close" class="text-base" />
		</button>
	</div>

	{
		config.author && (
			<div class="live2d-author" id="live2d-author">
				<span>by </span>
				{config.author.url ? (
					<a
						href={config.author.url}
						target="_blank"
						rel="noopener noreferrer"
					>
						{config.author.name}
					</a>
				) : (
					<span>{config.author.name}</span>
				)}
			</div>
		)
	}

	<div class="live2d-group-indicator" id="live2d-group-indicator" />
</div>

<div class="live2d-trigger" id="live2d-trigger" title="显示看板娘">
	<div class="live2d-trigger-inner">
		<Icon name="fa7-regular:address-card" class="text-lg" />
		<span class="live2d-trigger-text">看板娘</span>
	</div>
</div>

<MessageBox />

<script
	is:inline
	define:vars={{ config, modelPathUrl: url(config.model.path) }}
>
	class Live2DStateManager {
		constructor() {
			this.state = "idle";
			this.loadPromise = null;
			this.loadError = null;
			this.retryCount = 0;
			this.maxRetries = 2;
			this.visibilityCache = null;
		}

		static async getInstance() {
			if (!Live2DStateManager._instance) {
				Live2DStateManager._instance = new Live2DStateManager();
				Live2DStateManager._instance.visibilityCache = localStorage.getItem("live2d-visibility-cache");
			}
			return Live2DStateManager._instance;
		}

		getState() {
			return this.state;
		}

		setState(newState) {
			const oldState = this.state;
			this.state = newState;
			if (newState === "error" || newState === "ready") {
				this.loadError = null;
			}
		}

		async ensureLoaded() {
			if (this.state === "ready") {
				return true;
			}
			if (this.state === "loading" && this.loadPromise) {
				try {
					await this.loadPromise;
					return this.state === "ready";
				} catch {
					return false;
				}
			}
			if (this.state === "error" && this.retryCount < this.maxRetries) {
				this.retryCount++;
				this.loadError = null;
			} else if (this.state === "error") {
				return false;
			}
			this.setState("loading");
			this.loadPromise = this.loadResources().then(() => {
				this.setState("ready");
				return true;
			}).catch((error) => {
				this.setState("error");
				this.loadError = error;
				return false;
			});
			return this.loadPromise;
		}

		async loadResources() {
			await Live2DStateManager.loadScript(
				"https://cubism.live2d.com/sdk-web/cubismcore/live2dcubismcore.min.js",
			);
			await Live2DStateManager.loadScript(
				"https://cdn.jsdelivr.net/npm/pixi.js@6.5.10/dist/browser/pixi.min.js",
			);
			await Live2DStateManager.loadScript(
				"https://cdn.jsdelivr.net/npm/pixi-live2d-display/dist/cubism4.min.js",
			);
			if (!window.PIXI || !window.PIXI.live2d) {
				throw new Error("PIXI or live2d not available");
			}
			return true;
		}

		static loadScript(src) {
			return new Promise((resolve, reject) => {
				if (document.querySelector(`script[src="${src}"]`)) {
					resolve();
					return;
				}
				const s = document.createElement("script");
				s.src = src;
				s.crossOrigin = "anonymous";
				s.onload = resolve;
				s.onerror = () => reject(new Error(`Failed to load: ${src}`));
				document.head.appendChild(s);
			});
		}

		getCachedVisibility() {
			return this.visibilityCache;
		}

		setCachedVisibility(visible) {
			this.visibilityCache = visible ? "visible" : "hidden";
			localStorage.setItem("live2d-visibility-cache", this.visibilityCache);
		}
	}

	let stateManager = null;
	let live2dApp = null;
	let live2dModel = null;
	let isResourcesReady = false;
	let isWidgetVisible = false;
	let resourceLoadPromise = null;
	let isDragSetup = false;

	async function ensureResourcesLoaded() {
		if (isResourcesReady) {
			return true;
		}
		if (resourceLoadPromise) {
			return resourceLoadPromise;
		}
		resourceLoadPromise = (async () => {
			try {
				stateManager = await Live2DStateManager.getInstance();
				const loaded = await stateManager.ensureLoaded();
				if (loaded && window.PIXI?.live2d?.Live2DModel) {
					isResourcesReady = true;
					return true;
				}
				return false;
			} catch {
				resourceLoadPromise = null;
				return false;
			}
		})();
		return resourceLoadPromise;
	}

	async function initLive2D() {
		if (!config.model || !config.model.path) {
			return false;
		}
		const resourcesReady = await ensureResourcesLoaded();
		if (!resourcesReady) {
			handleLoadError();
			return false;
		}
		try {
			const canvas = document.getElementById("live2d-canvas");
			if (!canvas) {
				return false;
			}
			const size = config.size || { width: 280, height: 250 };
			const resolution =
				config.resolution || Math.min(window.devicePixelRatio || 1, 2);

			if (window._live2dApp) {
				try {
					window._live2dApp.destroy(true, { children: true, texture: true, baseTexture: true });
				} catch {
					// ignore
				}
				window._live2dApp = null;
				window._live2dModel = null;
			}
			live2dApp = null;
			live2dModel = null;

			live2dApp = new PIXI.Application({
				view: canvas,
				width: size.width,
				height: size.height,
				backgroundAlpha: 0,
				antialias: true,
				resolution: resolution,
				autoDensity: true,
			});

			live2dModel = await PIXI.live2d.Live2DModel.from(modelPathUrl);
			console.log("[Live2D] Model loaded successfully:", modelPathUrl, "model width:", live2dModel.width, "model height:", live2dModel.height);

			const scaleX = size.width / live2dModel.width;
			const scaleY = size.height / live2dModel.height;
			const fitScale = Math.min(scaleX, scaleY);
			live2dModel.scale.set(fitScale);
			live2dModel.anchor.set(0.5, 0.5);
			live2dModel.x = size.width / 2;
			live2dModel.y = size.height / 2;

			live2dApp.stage.addChild(live2dModel);

			window._live2dApp = live2dApp;
			window._live2dModel = live2dModel;

			setupInteractions();
			scheduleIdleAnimation();
			return true;
		} catch (error) {
			console.error("[Live2D] Initialization failed:", error);
			handleLoadError();
			return false;
		}
	}

	function handleLoadError() {
		const widget = document.getElementById("live2d-widget");
		if (widget) {
			widget.classList.remove("live2d-initial");
		}
	}

	function setupInteractions() {
		const allMotionGroups = ["Expression", "TapShort", "TapLong", "Other"];
		let clickMotionGroups = ["Expression", "TapShort"];
		let currentGroupIndex = 0;

		live2dModel.on("hit", (_hitAreas) => {
			if (!window._live2dWasDragging) playRandomMotion();
			window._live2dWasDragging = false;
		});

		const canvas = document.getElementById("live2d-canvas");
		canvas?.addEventListener("click", () => {
			if (!window._live2dWasDragging) playRandomMotion();
			window._live2dWasDragging = false;
		});

		const switchBtn = document.getElementById("toolbar-switch");
		const groupIndicator = document.getElementById("live2d-group-indicator");
		let indicatorTimer = null;

		if (switchBtn) {
			switchBtn.addEventListener("click", (e) => {
				e.stopPropagation();
				currentGroupIndex = (currentGroupIndex + 1) % allMotionGroups.length;
				clickMotionGroups = [allMotionGroups[currentGroupIndex]];
				if (groupIndicator) {
					const groupNames = {
						Expression: "表情",
						TapShort: "短动画",
						TapLong: "长动画",
						Other: "其他",
					};
					groupIndicator.textContent = groupNames[allMotionGroups[currentGroupIndex]] || allMotionGroups[currentGroupIndex];
					groupIndicator.classList.add("show");
					clearTimeout(indicatorTimer);
					indicatorTimer = setTimeout(() => groupIndicator.classList.remove("show"), 1500);
				}
				if (live2dModel) {
					try {
						live2dModel.motion(clickMotionGroups[0], undefined, 2);
						live2dModel.expression();
					} catch {
						// ignore
					}
				}
			});
		}

		const infoBtn = document.getElementById("toolbar-info");
		const authorPanel = document.getElementById("live2d-author");

		if (infoBtn && authorPanel) {
			infoBtn.addEventListener("click", (e) => {
				e.stopPropagation();
				authorPanel.classList.toggle("visible");
				infoBtn.classList.toggle("active");
			});
		}

		const dragBtn = document.getElementById("toolbar-drag");
		if (dragBtn) {
			dragBtn.addEventListener("click", (e) => {
				e.stopPropagation();
			});
		}

		const closeBtn = document.getElementById("toolbar-close");
		if (closeBtn) {
			closeBtn.addEventListener("click", (e) => {
				e.stopPropagation();
				closeLive2DWidget();
			});
		}

		function playRandomMotion() {
			if (!live2dModel) return;
			clearTimeout(window._live2dIdleTimer);
			try {
				const group = clickMotionGroups[Math.floor(Math.random() * clickMotionGroups.length)];
				live2dModel.motion(group, undefined, 2);
				live2dModel.expression();
			} catch {
				// ignore
			}
			showMessage();
			scheduleIdleAnimation();
		}

		setupDrag();
	}

	function scheduleIdleAnimation() {
		clearTimeout(window._live2dIdleTimer);
		const delay = 15000 + Math.random() * 15000;
		window._live2dIdleTimer = setTimeout(() => {
			if (live2dModel && isWidgetVisible) {
				try {
					live2dModel.motion("Idle", 0, 1);
					live2dModel.expression();
				} catch {
					// ignore
				}
			}
			scheduleIdleAnimation();
		}, delay);
	}

	function triggerEntryAnimation() {
		const widget = document.getElementById("live2d-widget");
		const author = document.getElementById("live2d-author");
		if (!widget) return;

		widget.classList.remove("live2d-initial");
		widget.classList.add("live2d-entering");

		setTimeout(() => {
			widget.classList.remove("live2d-entering");
			widget.classList.add("live2d-ready");
			if (author) {
				author.classList.add("visible");
			}
		}, 600);
	}

	async function closeLive2DWidget() {
		const widget = document.getElementById("live2d-widget");
		if (!widget) return;

		if (window.clearModelMessage) {
			window.clearModelMessage();
		}

		const author = document.getElementById("live2d-author");
		if (author) {
			author.classList.remove("visible");
		}

		const rect = widget.getBoundingClientRect();
		const viewportHeight = window.innerHeight;
		const distanceToBottom = viewportHeight - rect.bottom;

		widget.style.setProperty("--fall-distance", `${distanceToBottom}px`);
		widget.classList.add("live2d-falling");

		await sleep(300);

		widget.classList.remove("live2d-falling");
		widget.classList.add("live2d-exiting");

		await sleep(400);

		widget.style.visibility = "hidden";
		widget.style.pointerEvents = "none";
		widget.classList.remove("live2d-exiting");
		isWidgetVisible = false;

		if (stateManager) {
			stateManager.setCachedVisibility(false);
		}

		updateTriggerVisibility(true);

		window.dispatchEvent(
			new CustomEvent("live2d-visibility-change", {
				detail: { visible: false },
			}),
		);
	}

	async function showLive2DWidget() {
		const widget = document.getElementById("live2d-widget");
		if (!widget) return;

		updateTriggerVisibility(false);

		const resourcesReady = await ensureResourcesLoaded();
		if (!resourcesReady) {
			updateTriggerVisibility(true);
			return;
		}

		const currentCanvas = document.getElementById("live2d-canvas");
		const canvasValid = currentCanvas && window._live2dApp?.renderer?.view === currentCanvas;
		const modelExists = window._live2dApp && window._live2dModel && canvasValid;

		if (modelExists) {
			widget.style.visibility = "";
			widget.style.pointerEvents = "";
			widget.style.opacity = "";
			widget.style.transform = "";
			widget.classList.remove("live2d-initial", "live2d-ready", "live2d-exiting", "live2d-falling");
			isWidgetVisible = true;
			window._live2dApp?.ticker?.start();
			window._live2dApp?.render();
			triggerEntryAnimation();
		} else {
			if (window._live2dApp) {
				try {
					window._live2dApp.destroy(true, { children: true, texture: true, baseTexture: true });
				} catch {
					// ignore
				}
				window._live2dApp = null;
				window._live2dModel = null;
			}
			live2dApp = null;
			live2dModel = null;

			const initialized = await initLive2D();
			if (initialized) {
				widget.style.visibility = "";
				widget.style.pointerEvents = "";
				widget.style.opacity = "";
				widget.style.transform = "";
				widget.classList.remove("live2d-initial", "live2d-ready", "live2d-exiting", "live2d-falling");
				isWidgetVisible = true;
				triggerEntryAnimation();
			} else {
				updateTriggerVisibility(true);
				return;
			}
		}

		if (stateManager) {
			stateManager.setCachedVisibility(true);
		}

		window.dispatchEvent(
			new CustomEvent("live2d-visibility-change", {
				detail: { visible: true },
			}),
		);
	}

	function updateTriggerVisibility(show) {
		const trigger = document.getElementById("live2d-trigger");
		if (!trigger) return;
		if (show) {
			trigger.classList.add("visible");
		} else {
			trigger.classList.remove("visible");
		}
	}

	function initTrigger() {
		const trigger = document.getElementById("live2d-trigger");
		if (!trigger) return;

		trigger.addEventListener("click", () => {
			showLive2DWidget();
		});

		const cachedVisibility = stateManager?.getCachedVisibility();
		if (cachedVisibility === "hidden") {
			updateTriggerVisibility(true);
			const widget = document.getElementById("live2d-widget");
			if (widget) {
				widget.style.visibility = "hidden";
				widget.style.pointerEvents = "none";
			}
		} else if (cachedVisibility === "visible") {
			isWidgetVisible = true;
		}
	}

	window._showLive2DWidget = showLive2DWidget;
	window._closeLive2DWidget = closeLive2DWidget;

	function setupDrag() {
		if (isDragSetup) return;
		isDragSetup = true;
		const container = document.getElementById("live2d-widget");
		if (!container) return;

		let isDragging = false;
		let dragStart = { x: 0, y: 0 };
		let containerStart = { x: 0, y: 0 };
		let dragMoved = false;
		const DRAG_THRESHOLD = 5;
		let animFrameId = 0;
		let pendingMove = false;
		let moveTarget = { x: 0, y: 0 };
		let winWidth = window.innerWidth;
		let winHeight = window.innerHeight;
		let containerW = container.offsetWidth;
		let containerH = container.offsetHeight;

		function rafMove() {
			if (!pendingMove) return;
			pendingMove = false;
			container.style.left = moveTarget.x + "px";
			container.style.top = moveTarget.y + "px";
		}

		function scheduleMove(x, y) {
			moveTarget.x = x;
			moveTarget.y = y;
			pendingMove = true;
			if (!animFrameId) {
				animFrameId = requestAnimationFrame(() => {
					animFrameId = 0;
					rafMove();
				});
			}
		}

		container.addEventListener("mousedown", (e) => {
			if (e.button !== 0) return;
			isDragging = true;
			dragMoved = false;
			dragStart = { x: e.clientX, y: e.clientY };
			const rect = container.getBoundingClientRect();
			containerStart = { x: rect.left, y: rect.top };
			containerW = container.offsetWidth;
			containerH = container.offsetHeight;
			container.style.cursor = "grabbing";
			container.style.willChange = "left, top";
			e.preventDefault();
		});

		document.addEventListener("mousemove", (e) => {
			if (!isDragging) return;
			const dx = e.clientX - dragStart.x;
			const dy = e.clientY - dragStart.y;
			if (Math.abs(dx) > DRAG_THRESHOLD || Math.abs(dy) > DRAG_THRESHOLD) {
				dragMoved = true;
			}
			const clampedX = Math.max(0, Math.min(containerStart.x + dx, winWidth - containerW));
			const clampedY = Math.max(0, Math.min(containerStart.y + dy, winHeight - containerH));
			scheduleMove(clampedX, clampedY);
		});

		document.addEventListener("mouseup", () => {
			if (isDragging) {
				isDragging = false;
				container.style.willChange = "auto";
				if (animFrameId) {
					cancelAnimationFrame(animFrameId);
					animFrameId = 0;
				}
				if (pendingMove) rafMove();
				if (dragMoved) {
					window._live2dWasDragging = true;
				}
				container.style.cursor = "grab";
			}
		});

		container.addEventListener("touchstart", (e) => {
			if (e.touches.length !== 1) return;
			isDragging = true;
			dragMoved = false;
			const touch = e.touches[0];
			dragStart = { x: touch.clientX, y: touch.clientY };
			const rect = container.getBoundingClientRect();
			containerStart = { x: rect.left, y: rect.top };
			containerW = container.offsetWidth;
			containerH = container.offsetHeight;
			container.style.willChange = "left, top";
			e.preventDefault();
		});

		document.addEventListener("touchmove", (e) => {
			if (!isDragging || e.touches.length !== 1) return;
			const touch = e.touches[0];
			const dx = touch.clientX - dragStart.x;
			const dy = touch.clientY - dragStart.y;
			if (Math.abs(dx) > DRAG_THRESHOLD || Math.abs(dy) > DRAG_THRESHOLD) {
				dragMoved = true;
			}
			const clampedX = Math.max(0, Math.min(containerStart.x + dx, winWidth - containerW));
			const clampedY = Math.max(0, Math.min(containerStart.y + dy, winHeight - containerH));
			scheduleMove(clampedX, clampedY);
			e.preventDefault();
		});

		document.addEventListener("touchend", () => {
			if (isDragging) {
				container.style.willChange = "auto";
				if (animFrameId) {
					cancelAnimationFrame(animFrameId);
					animFrameId = 0;
				}
				if (pendingMove) rafMove();
				if (dragMoved) {
					window._live2dWasDragging = true;
				}
			}
			isDragging = false;
		});

		container.style.cursor = "grab";

		window.addEventListener("resize", () => {
			winWidth = window.innerWidth;
			winHeight = window.innerHeight;
			containerW = container.offsetWidth;
			containerH = container.offsetHeight;
			const rect = container.getBoundingClientRect();
			const maxX = winWidth - containerW;
			const maxY = winHeight - containerH;
			if (rect.left > maxX) {
				container.style.left = maxX + "px";
				container.style.right = "auto";
			}
			if (rect.top > maxY) {
				container.style.top = maxY + "px";
				container.style.bottom = "auto";
			}
		});
	}

	function showMessage() {
		const messages = config.interactive?.clickMessages || [
			"你好！",
			"有什么需要帮助的吗？",
			"今天天气真不错呢！",
			"要不要一起玩游戏？",
			"记得按时休息哦！",
		];
		const randomMessage = messages[Math.floor(Math.random() * messages.length)];
		if (window.showModelMessage) {
			window.showModelMessage(randomMessage, {
				containerId: "live2d-widget",
				displayTime: config.interactive?.messageDisplayTime || 3000,
			});
		}
	}

	function handleResponsive() {
		const widget = document.getElementById("live2d-widget");
		if (!widget) return;
		const cachedVisibility = stateManager?.getCachedVisibility();
		if (cachedVisibility === "hidden") return;
		if (config.responsive?.hideOnMobile) {
			const breakpoint = config.responsive.mobileBreakpoint || 768;
			widget.style.visibility = window.innerWidth <= breakpoint ? "hidden" : "";
			widget.style.pointerEvents = window.innerWidth <= breakpoint ? "none" : "";
		}
	}

	async function initialize() {
		stateManager = await Live2DStateManager.getInstance();
		initTrigger();

		const cachedVisibility = stateManager.getCachedVisibility();
		if (cachedVisibility === "hidden") {
			const widget = document.getElementById("live2d-widget");
			if (widget) {
				widget.style.visibility = "hidden";
				widget.style.pointerEvents = "none";
			}
		} else {
			isWidgetVisible = true;
			await initLive2D();
			if (live2dModel) {
				triggerEntryAnimation();
			}
		}

		handleResponsive();
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initialize);
	} else {
		initialize();
	}

	window.addEventListener("resize", handleResponsive);

	function sleep(ms) {
		return new Promise((resolve) => setTimeout(resolve, ms));
	}
</script>

<style>
	.live2d-widget {
		position: fixed;
		z-index: 999;
		pointer-events: auto;
		cursor: grab;
	}

	.live2d-widget.live2d-initial {
		opacity: 0;
		transform: translateY(120%);
		pointer-events: none;
